# ── LLM Providers (all optional — fallback chain tries each in order) ──

# OpenAI (paid)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Local (completely free, no keys needed)
# Ollama is auto-detected if running at http://127.0.0.1:11434
# OLLAMA_ENABLED=true
# OLLAMA_MODEL=qwen2.5:0.5b

# Groq — fast free tier, no credit card: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — generous free tier, no credit card: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# NVIDIA NIM — free prototyping tier: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenRouter — many free models, one key: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1:free

# Together AI — free credits, no credit card: https://together.ai
TOGETHER_API_KEY=your_together_api_key_here
# TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# HuggingFace Inference API — free tier: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Cloudflare Workers AI — free tier: https://dash.cloudflare.com
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# ── SMTP for email verification ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your.email@gmail.com