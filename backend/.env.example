# OpenAI (optional — backend works with DuckDuckGo-only without it)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# SMTP for email verification (required for sending verification codes)
# Gmail example (use App Password, not your regular password):
#   1. Enable 2FA at https://myaccount.google.com/security
#   2. Create App Password at https://myaccount.google.com/apppasswords
#   3. Use that 16-char password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your.email@gmail.com
