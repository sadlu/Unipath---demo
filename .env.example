# UniPath Environment Configuration
# Copy this file to backend/.env and fill in your keys

# --- SMTP (for email verification) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com

# --- AI Providers (at least one required for LLM features) ---
# Groq (fast, generous free tier): https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_key
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free tier, no credit card): https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# Ollama (local, completely free): https://ollama.ai
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.2:1b

# --- Optional AI Providers ---
# NVIDIA_API_KEY=nvapi-...
# OPENROUTER_API_KEY=sk-or-...
# HUGGINGFACE_API_KEY=hf_...
# CLOUDFLARE_API_KEY=...
# CLOUDFLARE_ACCOUNT_ID=...
# TOGETHER_API_KEY=...
# OPENAI_API_KEY=sk-...

# --- Database ---
# DATABASE_URL=postgresql://user:pass@host/db
# UNIPATH_DATA_DIR=/path/to/data

# --- Server ---
# PORT=8000
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173
