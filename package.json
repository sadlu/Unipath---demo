{
  "name": "unipath",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "description": "UniPath Desktop - Opportunity Discovery Platform",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "electron .",
    "preview": "vite preview",
    "build:backend": "python scripts/build_backend.py",
    "dist": "npm run build && npm run build:backend && electron-builder --publish=never",
    "dist:linux": "npm run build && npm run build:backend && electron-builder --linux --publish=never",
    "dist:win": "npm run build && npm run build:backend && electron-builder --win --publish=never",
    "dist:mac": "npm run build && npm run build:backend && electron-builder --mac --publish=never"
  },
  "build": {
    "appId": "com.unipath.desktop",
    "productName": "UniPath",
    "directories": {
      "output": "dist-setup"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-backend",
        "to": "backend-bin",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Education",
      "icon": "unipath-icon.svg"
    },
    "win": {
      "target": ["nsis"],
      "icon": "unipath-icon.svg"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "unipath-icon.svg",
      "category": "public.app-category.education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
