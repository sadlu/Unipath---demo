{
  "name": "unipath",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "description": "UniPath Desktop - Opportunity Discovery Platform",
  "author": {
    "name": "UniPath",
    "email": "fazad9@gmail.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "start": "electron .",
    "preview": "vite preview",
    "build:backend": "python scripts/build_backend.py",
    "build:backend:bash": "bash scripts/build-backend.sh",
    "dist:full": "npm run build && npm run build:backend && electron-builder --publish=never",
    "dist:linux": "npm run build && npm run build:backend && electron-builder --linux --publish=never",
    "dist:win": "npm run build && npm run build:backend && electron-builder --win --publish=never",
    "dist:mac": "npm run build && npm run build:backend && electron-builder --mac --publish=never",
    "dist:installer": "npm run build && npm run build:backend && electron-builder --win --publish=never && installer\\build-installer.bat",
    "dist:installer:quick": "installer\\build-installer.bat"
  },
  "build": {
    "appId": "com.unipath.desktop",
    "productName": "UniPath",
    "directories": {
      "output": "dist-setup"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-backend",
        "to": "backend-bin",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon-512.png",
      "category": "Education"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon-512.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon-512.png",
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UniPath",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "warningsPerLicense": false,
      "deleteAppDataOnUninstall": false,
      "language": "1033"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@emotion/is-prop-valid": "^1.4.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@xenova/transformers": "^2.17.2",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
